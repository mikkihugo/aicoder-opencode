#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

if [[ $# -lt 1 ]]; then
  echo "usage: aicoder-opencode-product <target-name> [-- <opencode-args...>]" >&2
  exit 2
fi

TARGET_NAME="$1"
shift

cd "$REPO_ROOT"
exec node --enable-source-maps ./dist/cli.js launch-product "$TARGET_NAME" "$@"
