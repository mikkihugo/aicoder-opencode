{
  // Canonical control-plane model registry.
  // Keep provider order, tiers, quotas, and role intent here.
  "version": 1,
  "defaults": {
    "fields": [
      "id",
      "description",
      "capability_tier",
      "cost_tier",
      "billing_mode",
      "latency_tier",
      "concurrency",
      "quota_visibility",
      "best_for",
      "not_for",
      "default_roles",
      "provider_order",
      "notes"
    ]
  },
  "models": [
    {
      "id": "glm-5.1",
      "description": "Heavy reasoning and architecture lane for high-value decisions when cheaper GLM lanes are not enough.",
      "capability_tier": "frontier",
      "cost_tier": "expensive",
      "billing_mode": "quota",
      "latency_tier": "medium",
      "concurrency": 1,
      "quota_visibility": "system-observed",
      "best_for": [
        "architecture",
        "adversarial_review",
        "hard_debugging",
        "irreversible_decisions"
      ],
      "not_for": [
        "routine_coding",
        "generic_helper_fanout",
        "bulk_retry_loops"
      ],
      "default_roles": [
        "architect",
        "deep_reviewer",
        "oracle"
      ],
      "provider_order": [
        {
          "provider": "zai-coding-plan",
          "model": "zai-coding-plan/glm-5.1",
          "priority": 1,
          "status": "disfavored"
        },
        {
          "provider": "ollama-cloud",
          "model": "ollama-cloud/glm-5.1",
          "priority": 2
        },
        {
          "provider": "opencode-go",
          "model": "opencode-go/glm-5.1",
          "priority": 3,
          "status": "disfavored"
        }
      ],
      "notes": [
        "Treat GLM-5, GLM-5.1, and GLM-5-Turbo as the same expensive family for routing.",
        "Keep behind GLM-4.7 and GLM-4.7-Flash because GLM-5.1 costs materially more."
      ]
    },
