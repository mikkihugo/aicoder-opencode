#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
MAINTENANCE_SERVICE_NAME="${LETTA_WORKSPACE_MAINTENANCE_SERVICE_NAME:-aicoder-opencode-main.service}"
MAINTENANCE_SERVER_URL="${LETTA_WORKSPACE_MAINTENANCE_SERVER_URL:-${LETTA_MAINTENANCE_SERVER_URL:-http://127.0.0.1:8080}}"
MAINTENANCE_AUTOMATION_USERNAME="${LETTA_WORKSPACE_MAINTENANCE_AUTOMATION_USERNAME:-${LETTA_MAINTENANCE_AUTOMATION_USERNAME:-opencode}}"
MAINTENANCE_PASSWORD_PATH="${LETTA_WORKSPACE_MAINTENANCE_PASSWORD_PATH:-$REPO_ROOT/.opencode/state/maintenance-web/server-password}"
LOG_DIRECTORY="$REPO_ROOT/.opencode/state/maintenance"
LOG_PATH="$LOG_DIRECTORY/maintenance-start.log"
START_MESSAGE="${1:-Maintenance iteration for letta-workspace. Follow this workflow strictly:
1. Consult roadmap_keeper for the next highest-value slice (read STATUS.md, ROADMAP.md, active plans, recent checkpoints, monorepo subproject state).
2. Dispatch planning_analyst and consumer_advocate in parallel for that slice. Planning must produce a Critical Files list; consumer_advocate must surface user-facing friction and unsafe defaults.
3. For every non-trivial slice, run a concrete partner/combatant pair in parallel before coding: use codebase_explorer or architecture_consultant as the supportive read helper, and use critical_reviewer or oracle as the adversarial read helper. Synthesize both reports yourself before editing.
4. Implement the change yourself, or delegate one tightly scoped implementation_worker task with exact paths, exact change, and one-sentence why.
5. Run verifier after changes. If regression or security risk is material, run critical_reviewer or security_reviewer as an additional read-only pass.
6. Commit when verified. Loop to step 1 for the next slice. Never ask the user unless the next move is destructive or irreversible; otherwise record the assumption in the checkpoint and continue.
7. Keep the session title and checkpoints clean and specific to letta-workspace maintenance.
8. **PDD Purpose gate — emit BEFORE any edit.** For every non-trivial slice, emit the 6-line Purpose block (OBSERVED: / PURPOSE: / WHY: / IF/THEN: / CONFIDENCE: 0.0-1.0 / GATE:) as specified in implementation_lead.md BEFORE touching code. Trivial reversible slices may emit a one-line RATIONALE: instead. CONFIDENCE < 0.7 blocks proceeding without an adversarial subagent pass (critical_reviewer / oracle / security_reviewer). The Purpose block is your visible proof the gate was run.
9. **Subagent output guard.** If any dispatched specialist returns zero text (step-start + step-finish with no content parts), treat it as a failed MCP 503 dispatch, NOT as no feedback. Retry with a different-lineage model. Never synthesize on empty input. Record reviewer=empty, retried=MODEL in slice notes.

Spec-kit is the canonical scaffold: shape every non-trivial slice as /specify (spec from .specify/templates/spec-template.md) -> /plan (plan from plan-template.md) -> /tasks (tasks from tasks-template.md) -> /implement. PM skills (pm-outcome-roadmap, pm-create-prd, pm-brainstorm-okrs, pm-prioritization-frameworks, pm-pre-mortem) feed the spec; planning_analyst feeds the plan; implementation_lead executes tasks.}"
SESSION_TITLE="${LETTA_WORKSPACE_MAINTENANCE_SESSION_TITLE:-${LETTA_MAINTENANCE_SESSION_TITLE:-letta-workspace-maintenance}}"
SESSION_ID_FILE="$LOG_DIRECTORY/session-id"
RUNNER_UNIT_NAME="${LETTA_WORKSPACE_MAINTENANCE_RUNNER_UNIT_NAME:-letta-workspace-maintenance-run.service}"
GENERIC_MAINTENANCE_TITLE_REGEX="${LETTA_WORKSPACE_MAINTENANCE_GENERIC_TITLE_REGEX:-${LETTA_MAINTENANCE_GENERIC_TITLE_REGEX:-\`?letta-workspace\`? maintenance|\`?letta-workspace\`? autonomous maintenance mode}}"
REMOTE_MESSAGE_READ_TIMEOUT_SECONDS="${LETTA_WORKSPACE_REMOTE_MESSAGE_READ_TIMEOUT_SECONDS:-120}"
ACTIVE_RUN_STALE_SECONDS="${LETTA_WORKSPACE_ACTIVE_RUN_STALE_SECONDS:-1200}"

list_remote_sessions() {
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$REPO_ROOT" <<'PY'
import base64
import json
import sys
import urllib.request
from pathlib import Path
from urllib.parse import quote

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
repo_root = sys.argv[4]
request = urllib.request.Request(f"{server_url}/session?directory={quote(repo_root, safe='/')}")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

with urllib.request.urlopen(request, timeout=5) as response:
    payload = response.read().decode("utf-8")
    print(payload)
PY
}

delete_remote_session() {
  local session_id="$1"
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$session_id" <<'PY'
import base64
import sys
import urllib.request
from pathlib import Path

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
session_id = sys.argv[4]
request = urllib.request.Request(f"{server_url}/session/{session_id}", method="DELETE")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

with urllib.request.urlopen(request, timeout=5):
    pass
PY
}

wait_for_remote_server() {
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" <<'PY'
import base64
import sys
import time
import urllib.request
from pathlib import Path

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
request = urllib.request.Request(f"{server_url}/session")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

deadline = time.time() + 30
last_error = None
while time.time() < deadline:
    try:
        with urllib.request.urlopen(request, timeout=2):
            sys.exit(0)
    except Exception as exc:
        last_error = exc
        time.sleep(1)

raise SystemExit(f"letta-workspace-maintenance: shared server not ready: {last_error}")
PY
}

create_remote_session() {
  local session_title="$1"
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$REPO_ROOT" "$session_title" <<'PY'
import base64
import json
import sys
import urllib.request
import urllib.error
from pathlib import Path
from urllib.parse import quote

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
repo_root = sys.argv[4]
session_title = sys.argv[5]
body = json.dumps({"title": session_title}).encode("utf-8")
request = urllib.request.Request(
    f"{server_url}/session?directory={quote(repo_root, safe='/')}",
    data=body,
    method="POST",
)
request.add_header("Content-Type", "application/json")
request.add_header("Accept", "application/json")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

with urllib.request.urlopen(request, timeout=30) as response:
    payload = json.loads(response.read().decode("utf-8"))
    print(payload["id"])
PY
}

session_requires_rotation() {
  local session_id="$1"
  local expected_agent="$2"
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$session_id" "$expected_agent" <<'PY'
import base64
import json
import sys
import urllib.request
from pathlib import Path

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
session_id = sys.argv[4]
expected_agent = sys.argv[5]
request = urllib.request.Request(f"{server_url}/session/{session_id}/message")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

try:
    with urllib.request.urlopen(request, timeout=30) as response:
        messages = json.loads(response.read().decode("utf-8"))
except urllib.error.URLError:
    print("missing-session")
    raise SystemExit(0)

if not messages:
    print("empty-session")
    raise SystemExit(0)

for message in messages:
    info = message.get("info") or {}
    if info.get("role") != "user":
        continue

    agent_name = info.get("agent")
    if isinstance(agent_name, str) and agent_name and agent_name != expected_agent:
        print("foreign-agent")
        raise SystemExit(0)

raise SystemExit(1)
PY
}

session_has_active_assistant_run() {
  local session_id="$1"
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$session_id" <<'PY'
import base64
import json
import sys
import urllib.request
import urllib.error
from pathlib import Path

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
session_id = sys.argv[4]
request = urllib.request.Request(f"{server_url}/session/{session_id}/message")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

try:
    with urllib.request.urlopen(request, timeout=30) as response:
        messages = json.loads(response.read().decode("utf-8"))
except urllib.error.URLError:
    raise SystemExit(1)

for message in reversed(messages):
    info = message.get("info") or {}
    if info.get("role") != "assistant":
        continue

    finish = info.get("finish")
    if isinstance(finish, str) and finish:
        raise SystemExit(1)

    print("assistant-active")
    raise SystemExit(0)

raise SystemExit(1)
PY
}

session_has_stale_assistant_run() {
  local session_id="$1"
  local stale_after_seconds="$2"
  # Heartbeat-based staleness: an assistant run is stale only when the last
  # assistant message has no finish marker AND the session-level time.updated
  # hasn't advanced for stale_after_seconds. opencode bumps time.updated on
  # every part write, so a genuinely long-running tool call stays alive as
  # long as it keeps streaming — we no longer kill real work just because
  # the message was *created* 20 min ago. Falls back to info.time.created if
  # time.updated is missing.
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$session_id" "$stale_after_seconds" "$REPO_ROOT" <<'PY'
import base64
import json
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from urllib.parse import quote

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
session_id = sys.argv[4]
stale_after_seconds = int(sys.argv[5])
repo_root = sys.argv[6]

def _auth(req):
    if password_path.exists():
        pw = password_path.read_text(encoding="utf-8").strip()
        if pw:
            token = base64.b64encode(f"{username}:{pw}".encode("utf-8")).decode("ascii")
            req.add_header("Authorization", f"Basic {token}")

message_req = urllib.request.Request(f"{server_url}/session/{session_id}/message")
_auth(message_req)
try:
    with urllib.request.urlopen(message_req, timeout=30) as response:
        messages = json.loads(response.read().decode("utf-8"))
except urllib.error.URLError:
    raise SystemExit(1)

last_assistant = None
for message in reversed(messages):
    info = message.get("info") or {}
    if info.get("role") == "assistant":
        last_assistant = info
        break

if not last_assistant:
    raise SystemExit(1)

finish = last_assistant.get("finish")
if isinstance(finish, str) and finish:
    raise SystemExit(1)

session_updated_ms = None
session_req = urllib.request.Request(
    f"{server_url}/session?directory={quote(repo_root, safe='/')}"
)
_auth(session_req)
try:
    with urllib.request.urlopen(session_req, timeout=30) as response:
        sessions = json.loads(response.read().decode("utf-8"))
    for session in sessions:
        if session.get("id") == session_id:
            session_updated_ms = (session.get("time") or {}).get("updated")
            break
except urllib.error.URLError:
    session_updated_ms = None

if isinstance(session_updated_ms, (int, float)):
    heartbeat_ms = int(session_updated_ms)
else:
    created = (last_assistant.get("time") or {}).get("created")
    heartbeat_ms = int(created) if isinstance(created, (int, float)) else 0

now_ms = int(time.time() * 1000)
if heartbeat_ms > 0 and now_ms - heartbeat_ms >= stale_after_seconds * 1000:
    print("assistant-stale")
    raise SystemExit(0)

raise SystemExit(1)
PY
}

send_remote_prompt() {
  local session_id="$1"
  local agent_name="$2"
  local prompt_text="$3"
  python3 - "$MAINTENANCE_SERVER_URL" "$MAINTENANCE_AUTOMATION_USERNAME" "$MAINTENANCE_PASSWORD_PATH" "$REPO_ROOT" "$session_id" "$agent_name" "$prompt_text" "$REMOTE_MESSAGE_READ_TIMEOUT_SECONDS" <<'PY'
import base64
import http.client
import json
import sys
import urllib.request
from pathlib import Path
from urllib.parse import quote

server_url = sys.argv[1].rstrip("/")
username = sys.argv[2]
password_path = Path(sys.argv[3])
repo_root = sys.argv[4]
session_id = sys.argv[5]
agent_name = sys.argv[6]
prompt_text = sys.argv[7]
body = {
    "agent": agent_name,
    "parts": [
        {
            "type": "text",
            "text": prompt_text,
        }
    ],
}

request = urllib.request.Request(
    f"{server_url}/session/{quote(session_id, safe='')}/message?directory={quote(repo_root, safe='/')}",
    data=json.dumps(body).encode("utf-8"),
    method="POST",
)
request.add_header("Content-Type", "application/json")
request.add_header("Accept", "application/json")

if password_path.exists():
    password = password_path.read_text(encoding="utf-8").strip()
    if password:
        token = base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")
        request.add_header("Authorization", f"Basic {token}")

with urllib.request.urlopen(request, timeout=30) as response:
    print(json.dumps({
        "accepted": True,
        "status": response.status,
        "sessionID": session_id,
        "agent": agent_name,
    }))
PY
}

stop_legacy_runner() {
  systemctl --user stop "$RUNNER_UNIT_NAME" >/dev/null 2>&1 || true
}

mkdir -p "$LOG_DIRECTORY"
touch "$LOG_PATH"
exec >>"$LOG_PATH" 2>&1
echo "[$(date -Iseconds)] letta-workspace-maintenance: bootstrap start"
systemctl --user start "$MAINTENANCE_SERVICE_NAME" >/dev/null
wait_for_remote_server >/dev/null
REMOTE_SESSIONS_JSON="$(list_remote_sessions)"

SESSION_SELECTION_JSON="$(python3 - "$REMOTE_SESSIONS_JSON" "$SESSION_TITLE" "$GENERIC_MAINTENANCE_TITLE_REGEX" "$REPO_ROOT" <<'PY'
import json
import re
import sys

sessions = json.loads(sys.argv[1]) if sys.argv[1].strip() else []
session_title = sys.argv[2]
generic_title_regex = re.compile(sys.argv[3], re.IGNORECASE)
repo_root = sys.argv[4]
matching_sessions = [
    session
    for session in sessions
    if str(session.get("title", "")) == session_title
    and str(session.get("directory", "")) == repo_root
]
matching_sessions.sort(key=lambda item: int(item.get("time", {}).get("updated", 0)), reverse=True)
selected = matching_sessions[0]["id"] if matching_sessions else ""
duplicates = [session["id"] for session in matching_sessions[1:]]
generic_conflicts = [
    session["id"]
    for session in sessions
    if str(session.get("directory", "")) == repo_root
    and str(session.get("title", "")) != session_title
    and generic_title_regex.search(str(session.get("title", "")))
]
print(json.dumps({"selected": selected, "duplicates": duplicates, "genericConflicts": generic_conflicts}))
PY
)"

EXISTING_SESSION_ID="$(python3 - "$SESSION_SELECTION_JSON" <<'PY'
import json
import sys

selection = json.loads(sys.argv[1])
print(selection.get("selected", ""))
PY
)"

DUPLICATE_SESSION_IDS="$(python3 - "$SESSION_SELECTION_JSON" <<'PY'
import json
import sys

selection = json.loads(sys.argv[1])
for session_id in selection.get("duplicates", []):
    print(session_id)
PY
)"

GENERIC_CONFLICT_SESSION_IDS="$(python3 - "$SESSION_SELECTION_JSON" <<'PY'
import json
import sys

selection = json.loads(sys.argv[1])
for session_id in selection.get("genericConflicts", []):
    print(session_id)
PY
)"

cleanup_session_ids() {
  local session_ids="${1:-}"
  if [[ -z "$session_ids" ]]; then
    return
  fi

  while IFS= read -r session_id; do
    if [[ -z "$session_id" ]]; then
      continue
    fi
    delete_remote_session "$session_id"
  done <<<"$session_ids"
}

cleanup_session_ids "$DUPLICATE_SESSION_IDS"
cleanup_session_ids "$GENERIC_CONFLICT_SESSION_IDS"
if [[ -n "$EXISTING_SESSION_ID" ]]; then
  if session_requires_rotation "$EXISTING_SESSION_ID" "implementation_lead"; then
    echo "[$(date -Iseconds)] letta-workspace-maintenance: rotating polluted session $EXISTING_SESSION_ID"
    delete_remote_session "$EXISTING_SESSION_ID"
    EXISTING_SESSION_ID=""
  fi
fi

if [[ -n "$EXISTING_SESSION_ID" ]]; then
  if session_has_stale_assistant_run "$EXISTING_SESSION_ID" "$ACTIVE_RUN_STALE_SECONDS"; then
    echo "[$(date -Iseconds)] letta-workspace-maintenance: rotating stale active session $EXISTING_SESSION_ID"
    delete_remote_session "$EXISTING_SESSION_ID"
    EXISTING_SESSION_ID=""
  elif session_has_active_assistant_run "$EXISTING_SESSION_ID"; then
    echo "[$(date -Iseconds)] letta-workspace-maintenance: assistant still running in session $EXISTING_SESSION_ID"
    printf '%s\n' "$EXISTING_SESSION_ID" >"$SESSION_ID_FILE"
    echo "letta-workspace-maintenance: active run already in progress on $MAINTENANCE_SERVER_URL"
    exit 0
  fi
fi

if [[ -z "$EXISTING_SESSION_ID" ]]; then
  EXISTING_SESSION_ID="$(create_remote_session "$SESSION_TITLE")"
fi

printf '%s\n' "$EXISTING_SESSION_ID" >"$SESSION_ID_FILE"

stop_legacy_runner
echo "[$(date -Iseconds)] letta-workspace-maintenance: prompting session $EXISTING_SESSION_ID via $MAINTENANCE_SERVER_URL"
PROMPT_RESULT="$(send_remote_prompt "$EXISTING_SESSION_ID" "implementation_lead" "$START_MESSAGE")"
echo "[$(date -Iseconds)] letta-workspace-maintenance: prompt completed $PROMPT_RESULT"
NEW_SESSION_ID="$(python3 - "$(list_remote_sessions)" "$SESSION_TITLE" <<'PY'
import json
import sys

sessions = json.loads(sys.argv[1]) if sys.argv[1].strip() else []
session_title = sys.argv[2]
for session in sessions:
    if session.get("title") == session_title:
        print(session["id"])
        break
PY
)"

if [[ -n "$NEW_SESSION_ID" ]]; then
  printf '%s\n' "$NEW_SESSION_ID" >"$SESSION_ID_FILE"
fi

echo "letta-workspace-maintenance: seeded via $MAINTENANCE_SERVER_URL"
echo "log: $LOG_PATH"
