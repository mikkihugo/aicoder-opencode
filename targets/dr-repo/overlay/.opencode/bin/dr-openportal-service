#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
USER_SYSTEMD_DIRECTORY="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
SERVICE_NAME="dr-openportal.service"
SERVICE_PATH="$USER_SYSTEMD_DIRECTORY/$SERVICE_NAME"
OPENPORTAL_BIN="$REPO_ROOT/.opencode/bin/dr-openportal"

install_systemd_unit() {
  mkdir -p "$USER_SYSTEMD_DIRECTORY"
  cat >"$SERVICE_PATH" <<EOF
[Unit]
Description=dr-repo OpenPortal instance
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$REPO_ROOT
ExecStart=$OPENPORTAL_BIN
Restart=on-failure
RestartSec=5
Nice=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
EOF
  systemctl --user daemon-reload
}

case "${1:-status}" in
  install-systemd)
    install_systemd_unit
    echo "dr-openportal: installed $SERVICE_NAME"
    ;;
  start)
    install_systemd_unit
    systemctl --user enable --now "$SERVICE_NAME"
    echo "dr-openportal: enabled $SERVICE_NAME"
    ;;
  stop)
    systemctl --user disable --now "$SERVICE_NAME"
    echo "dr-openportal: disabled $SERVICE_NAME"
    ;;
  restart)
    install_systemd_unit
    systemctl --user restart "$SERVICE_NAME"
    echo "dr-openportal: restarted $SERVICE_NAME"
    ;;
  status)
    systemctl --user status "$SERVICE_NAME" --no-pager
    ;;
  *)
    echo "usage: dr-openportal-service [install-systemd|start|stop|restart|status]" >&2
    exit 2
    ;;
esac
