#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
AUTOPILOT_BIN="$REPO_ROOT/.opencode/bin/dr-autopilot"
OPENCODE_BIN="$REPO_ROOT/.opencode/bin/opencode"

"$AUTOPILOT_BIN" start
exec "$OPENCODE_BIN"
