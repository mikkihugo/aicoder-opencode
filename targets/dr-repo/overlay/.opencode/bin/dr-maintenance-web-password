#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
PASSWORD_PATH="$REPO_ROOT/.opencode/state/maintenance-web/server-password"

copy_with_clipboard_tool() {
  local password="$1"

  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$password" | wl-copy
    return 0
  fi

  if command -v xclip >/dev/null 2>&1; then
    printf '%s' "$password" | xclip -selection clipboard
    return 0
  fi

  if command -v xsel >/dev/null 2>&1; then
    printf '%s' "$password" | xsel --clipboard --input
    return 0
  fi

  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$password" | pbcopy
    return 0
  fi

  return 1
}

if [[ ! -s "$PASSWORD_PATH" ]]; then
  echo "dr-maintenance-web-password: missing maintenance web password at $PASSWORD_PATH" >&2
  exit 1
fi

PASSWORD="$(tr -d '\r\n' < "$PASSWORD_PATH")"

case "${1:-copy}" in
  copy)
    if copy_with_clipboard_tool "$PASSWORD"; then
      echo "maintenance web password copied"
      exit 0
    fi
    echo "dr-maintenance-web-password: no clipboard tool found; password file: $PASSWORD_PATH" >&2
    exit 1
    ;;
  print)
    printf '%s\n' "$PASSWORD"
    ;;
  path)
    printf '%s\n' "$PASSWORD_PATH"
    ;;
  *)
    echo "usage: dr-maintenance-web-password [copy|print|path]" >&2
    exit 2
    ;;
esac
