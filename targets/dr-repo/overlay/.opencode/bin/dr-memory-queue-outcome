#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
QUEUE_SCRIPT="${REPO_ROOT}/.opencode/plugins/dr-memory/queue-pending-outcome.mjs"

if [[ ! -f "${QUEUE_SCRIPT}" ]]; then
  echo "missing queue script: ${QUEUE_SCRIPT}" >&2
  exit 1
fi

exec node --experimental-strip-types "${QUEUE_SCRIPT}" "$@" --directory "${REPO_ROOT}"
