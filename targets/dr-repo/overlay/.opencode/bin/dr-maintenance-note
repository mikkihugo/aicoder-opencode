#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
NOTE_PATH="$REPO_ROOT/.opencode/state/autopilot/maintenance-operator-note.md"

usage() {
  echo "usage: dr-maintenance-note set <text> | print | path | clear" >&2
  exit 2
}

command_name="${1:-}"
shift || true

mkdir -p "$(dirname "$NOTE_PATH")"

case "$command_name" in
  set)
    note_text="${*:-}"
    if [[ -z "$note_text" ]]; then
      echo "dr-maintenance-note: note text is required" >&2
      exit 1
    fi
    cat >"$NOTE_PATH" <<EOF
## Operator Note

$note_text
EOF
    echo "maintenance operator note updated"
    ;;
  print)
    cat "$NOTE_PATH"
    ;;
  path)
    printf '%s\n' "$NOTE_PATH"
    ;;
  clear)
    rm -f "$NOTE_PATH"
    echo "maintenance operator note cleared"
    ;;
  *)
    usage
    ;;
esac
